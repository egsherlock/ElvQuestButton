--[[
    ExtraQuestButton Skin for ElvUI WindTools
    
    Native WindTools addon skin implementation.
    
    This file can be placed in:
    ElvUI_WindTools/Modules/Skins/Addons/ExtraQuestButton.lua
    
    And registered in:
    ElvUI_WindTools/Modules/Skins/Addons/Load_Addons.xml
    
    This skin applies the WindTools visual style to ExtraQuestButton:
    - Shadow/vignette effect (characteristic WindTools look)
    - Clean backdrop with ElvUI styling
    - Dynamic shadow color binding
    - MerathilisUI compatibility
]]

local W, F, E, L = unpack((select(2, ...))) ---@type WindTools, Functions, ElvUI, LocaleTable
local S = W.Modules.Skins ---@type Skins

local _G = _G

--[[
    Skin Function for ExtraQuestButton
    
    Called when ExtraQuestButton addon is loaded.
    Applies WindTools visual styling to the button.
]]
function S:ExtraQuestButton()
    -- Check if skins are enabled
    if not E.private.WT.skins.enable then
        return
    end
    
    -- Check if this specific addon skin is enabled
    if not E.private.WT.skins.addons.extraQuestButton then
        return
    end

    -- Get the button reference
    local Button = _G.ExtraQuestButton
    if not Button then
        return
    end

    -- Check if Masque is handling this button with a custom skin
    local Masque = LibStub('Masque', true)
    if Masque then
        local MasqueGroup = Masque:Group("ExtraQuestButton", "ExtraQuestButton")
        if MasqueGroup and MasqueGroup.db and MasqueGroup.db.SkinID and MasqueGroup.db.SkinID ~= "Blizzard" then
            -- Masque is handling the skinning with a custom skin, only apply shadow
            self:CreateBackdropShadow(Button, true)
            return
        end
    end

    -- Core Skinning: Apply backdrop and shadow
    self:SkinExtraQuestButtonCore(Button)

    -- Hook into button visibility changes to maintain skin
    self:SecureHookScript(Button, "OnShow", "ExtraQuestButton_OnShow")
end

--[[
    Core Skinning Logic
    
    Creates backdrop, shadow, and applies styling.
]]
function S:SkinExtraQuestButtonCore(button)
    if button.__windSkin then
        return
    end

    -- Create a backdrop for the button
    -- We attach it to the Icon region for precise positioning
    if button.Icon and not button.backdrop then
        button:CreateBackdrop("Transparent")
        
        if button.backdrop then
            button.backdrop:ClearAllPoints()
            button.backdrop:SetPoint("TOPLEFT", button.Icon, "TOPLEFT", -1, 1)
            button.backdrop:SetPoint("BOTTOMRIGHT", button.Icon, "BOTTOMRIGHT", 1, -1)
            button.backdrop:SetFrameLevel(button:GetFrameLevel())
        end
    end

    -- Apply WindTools shadow effect
    if button.backdrop then
        self:CreateShadow(button.backdrop)
        
        -- Bind shadow color with border for dynamic theming
        if button.backdrop.shadow and button.backdrop.shadow.__wind then
            self:BindShadowColorWithBorder(button.backdrop)
        end
        
        -- Apply MerathilisUI styling if available
        self:MerathilisUISkin(button.backdrop)
    else
        -- Fallback: apply shadow directly to button
        self:CreateShadow(button)
    end

    button.__windSkin = true
end

--[[
    OnShow Hook
    
    Ensures skin is reapplied when button becomes visible.
    ExtraQuestButton shows/hides dynamically based on quest items.
]]
function S:ExtraQuestButton_OnShow(button)
    if not button.__windSkin then
        self:SkinExtraQuestButtonCore(button)
    end
    
    -- Ensure shadow is visible
    if button.backdrop and button.backdrop.shadow then
        button.backdrop.shadow:Show()
    elseif button.shadow then
        button.shadow:Show()
    end
end

-- Register callback for when ExtraQuestButton addon loads
S:AddCallbackForAddon("ExtraQuestButton")
